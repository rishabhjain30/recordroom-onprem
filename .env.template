# RecordRoom On-Prem Configuration
# Copy this to .env and fill in the values
# Generated secrets should be created by scripts/install.sh

# ---- Domain ----
# The domain customers will access RecordRoom at
SITE_URL=https://recordroom.example.com

# ---- Postgres ----
POSTGRES_DB=recordroom
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_RANDOM

# ---- JWT (shared between GoTrue and backend) ----
JWT_SECRET=CHANGE_ME_GENERATE_64_CHAR_HEX
ANON_KEY=CHANGE_ME_GENERATED_BY_INSTALL_SCRIPT
SERVICE_ROLE_KEY=CHANGE_ME_GENERATED_BY_INSTALL_SCRIPT

# ---- Backend ----
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: override OpenAI endpoint for local LLM
# OPENAI_BASE_URL=http://localhost:11434/v1

# ---- Email (optional) ----
# SMTP for on-prem email (invitations, password reset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=recordroom@example.com
# Or use Resend (cloud email service)
# RESEND_API_KEY=

# ---- GHCR Auth (for pulling images) ----
# GHCR_TOKEN=ghp_your_token_here
